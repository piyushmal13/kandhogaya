{
  "name": "ifxtrades-institutional",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server.ts",
    "prebuild": "node scripts/gen-sitemap.js",
    "build": "vite build",
    "build:server": "esbuild ./server.ts --bundle --packages=external --platform=node --target=node20 --format=esm --outfile=dist/server.js",
    "build:all": "npm run build && npm run build:server",
    "apply-migrations": "node scripts/apply-migrations.js",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "start:dev": "cross-env NODE_ENV=development tsx server.ts",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "alt-check": "node scripts/altCheck.js",
    "sitemap": "node scripts/gen-sitemap.js && node scripts/gen-robots.js",
    "test": "npm run lint && npm run alt-check && vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@sentry/react": "^10.48.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.97.0",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cobe": "^0.6.5",
    "compression": "^1.8.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.19.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "gsap": "^3.15.0",
    "helmet": "^8.1.0",
    "idb-keyval": "^6.2.2",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jscodeshift": "^17.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.6.11",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "jscodeshift": "^17.3.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
