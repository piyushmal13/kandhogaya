{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(js|css|woff2?|ttf|eot|png|jpg|jpeg|gif|svg|ico|webp))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdn.jsdelivr.net; connect-src 'self' https://*.supabase.co https://www.googletagmanager.com https://www.google-analytics.com; worker-src 'self' blob:; frame-ancestors 'none';"
        },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/src/edge-functions/health.ts"
    },
    {
      "src": "/api/signals",
      "dest": "/src/edge-functions/api/signals.ts",
      "headers": { "cache-control": "s-maxage=30, stale-while-revalidate=60" }
    },
    {
      "src": "/api/webinars",
      "dest": "/src/edge-functions/api/webinars.ts",
      "headers": { "cache-control": "s-maxage=60, stale-while-revalidate=120" }
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/src/edge-functions/auth/verifyJwt.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "src/edge-functions/**/*.ts": {
      "runtime": "@vercel/node@3.x",
      "maxDuration": 10
    }
  },
  "github": {
    "enabled":   true,
    "autoMerge": false,
    "silent":    true
  }
}
